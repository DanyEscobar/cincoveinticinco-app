        },
        {
          "error": "minlength",
          "message": "El campo debe tener al menos 3 caracteres."
        }
      ]
    },
    {
      "type": "text",
      "name": "lastname",
      "label": "Apellido *",
      "class": "col-12 col-md-6",
      "validations": { 
        "required": true,
        "minlength": 3
      },
      "errors": [
        {
          "error": "required",
          "message": "Campo requerido."
        },
        {
          "error": "minlength",
          "message": "El campo debe tener al menos 3 caracteres."
        }
      ]
    },
    {
      "type": "email",
