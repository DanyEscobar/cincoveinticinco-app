{
  "title": "Contact",
  "button": {
    "message": "Enviar",
    "icon": "fas fa-arrow-right",
    "position": "right"
  },
  "fields": [
    {
      "type": "select",
      "name": "gender",
      "label": "Sexo *",
      "class": "col-12 col-md-6",
      "options": [],
      "validations": { 
        "required": true 
      },
      "errors": [
        {
          "error": "required",
          "message": "Campo requerido."
        }
      ]
    },
    {
      "type": "date",
      "name": "birthdate",
      "label": "Fecha de nacimiento *",
      "class": "col-12 col-md-6",
      "validations": { 
        "required": true,
        "validateAge": true
      },
      "errors": [
        {
          "error": "required",
          "message": "Campo requerido."
        },
        {
          "error": "underAge",
          "message": "Debes ser mayor de 18 años."
        }
      ]
    },
    {
      "type": "text",
